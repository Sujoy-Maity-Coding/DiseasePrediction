        </select>
        <br /><br />

        <label>Panic Attacks</label><br />
        <select asp-for="PanicAttack">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Work Pressure (1-10)</label><br />
        <input type="number" asp-for="WorkPressure" />
        <br /><br />

        <label>Family Problems</label><br />
        <select asp-for="FamilyProblems">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Depression Score (0-30)</label><br />
        <input type="number" asp-for="DepressionScore" />
        <br /><br />
    }

    @if (Model.Department == "Medicine")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Gender</label><br />
        <select asp-for="Gender">
            <option value="1">Male</option>
            <option value="0">Female</option>
        </select>
        <br /><br />

        <label>Glucose</label><br />
        <input type="number" asp-for="Glucose" />
        <br /><br />

        <label>BMI</label><br />
        <input type="number" step="0.1" asp-for="BMI" />
        <br /><br />

        <label>Blood Pressure</label><br />
        <input type="number" asp-for="BloodPressure" />
        <br /><br />

        <label>Insulin</label><br />
        <input type="number" asp-for="Insulin" />
        <br /><br />

        <label>Skin Thickness</label><br />
        <input type="number" asp-for="SkinThickness" />
        <br /><br />

        <label>Diabetes Pedigree Function</label><br />
        <input type="number" step="0.01" asp-for="DiabetesPedigreeFunction" />
        <br /><br />

        <label>Frequent Urination</label><br />
        <select asp-for="FrequentUrination">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Excessive Thirst</label><br />
        <select asp-for="ExcessiveThirst">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Sudden Weight Loss</label><br />
        <select asp-for="SuddenWeightLoss">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Fatigue</label><br />
        <select asp-for="Fatigue">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Blurred Vision</label><br />
        <select asp-for="BlurredVision">
