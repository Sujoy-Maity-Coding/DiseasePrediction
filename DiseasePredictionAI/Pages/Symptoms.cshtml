@page
@model DiseasePredictionAI.Pages.SymptomsModel

<h1>@Model.Department Prediction</h1>

<form method="post">

    <input type="hidden" asp-for="Department" />

    @if (Model.Department == "Cardiology")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Gender</label><br />
        <select asp-for="Gender">
            <option value="1">Male</option>
            <option value="0">Female</option>
        </select>
        <br /><br />

        <label>Chest Pain</label><br />
        <select asp-for="ChestPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Shortness of Breath</label><br />
        <select asp-for="ShortnessBreath">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Dizziness</label><br />
        <select asp-for="Dizziness">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Palpitations</label><br />
        <select asp-for="Palpitations">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Fatigue</label><br />
        <select asp-for="Fatigue">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Sweating</label><br />
        <select asp-for="Sweating">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Nausea</label><br />
        <select asp-for="Nausea">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Blood Pressure</label><br />
        <input type="number" asp-for="BloodPressure" />
        <br /><br />

        <label>Heart Rate</label><br />
        <input type="number" asp-for="HeartRate" />
        <br /><br />

        <label>Cholesterol</label><br />
        <input type="number" asp-for="Cholesterol" />
        <br /><br />

        <label>Diabetes History</label><br />
        <select asp-for="DiabetesHistory">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Smoking</label><br />
        <select asp-for="Smoking">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Obesity</label><br />
        <select asp-for="Obesity">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Family History of Heart Disease</label><br />
        <select asp-for="FamilyHistoryHeartDisease">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />
    }

    @if (Model.Department == "Orthopedic")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Gender</label><br />
        <select asp-for="Gender">
            <option value="1">Male</option>
            <option value="0">Female</option>
        </select>
        <br /><br />

        <label>Back Pain</label><br />
        <select asp-for="BackPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Neck Pain</label><br />
        <select asp-for="NeckPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Joint Pain</label><br />
        <select asp-for="JointPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Knee Pain</label><br />
        <select asp-for="KneePain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Hip Pain</label><br />
        <select asp-for="HipPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Shoulder Pain</label><br />
        <select asp-for="ShoulderPain">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Muscle Weakness</label><br />
        <select asp-for="MuscleWeakness">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Stiffness</label><br />
        <select asp-for="Stiffness">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Swelling</label><br />
        <select asp-for="Swelling">
