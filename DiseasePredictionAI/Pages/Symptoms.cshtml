        </select>
        <br /><br />
    }

    <button type="submit" class="btn btn-primary">
        Predict Disease
    </button>

</form>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div style="
        margin-top:30px;
        padding:20px;
        border-radius:10px;
        border:2px solid #f5c2c7;
        background:#f8d7da;
        color:#842029;">
        @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(Model.Disease))
{
    <div style="
        margin-top:30px;
        padding:25px;
        border-radius:15px;
        border:2px solid #ddd;
        background:#f8f9fa;">

        <h2>Prediction Result</h2>

        @if (Model.Disease == "Normal")
        {
            <h3 style="color:green;">
                @Model.Disease
            </h3>
        }
        else
        {
            <h3 style="color:red;">
                @Model.Disease
            </h3>
        }

        <p>
            <strong>Recommended Medicine:</strong>
            @Model.Medicine
        </p>

        <hr />

        <a href="/Symptoms?department=@Model.Department"
           class="btn btn-success">
            Predict Again
        </a>

    </div>
}
