        </select>
        <br /><br />

        <label>Difficulty Walking</label><br />
        <select asp-for="DifficultyWalking">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Previous Injury</label><br />
        <select asp-for="PreviousInjury">
            <option value="0">No</option>
            <option value="1">Yes</option>
        </select>
        <br /><br />

        <label>Bone Density</label><br />
        <input type="number" step="0.01" asp-for="BoneDensity" />
        <br /><br />

        <label>BMI</label><br />
        <input type="number" step="0.1" asp-for="BMI" />
        <br /><br />
    }

    @if (Model.Department == "Psychology")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Gender</label><br />
        <select asp-for="Gender">
            <option value="1">Male</option>
            <option value="0">Female</option>
        </select>
        <br /><br />

        <label>Stress Level (1-10)</label><br />
        <input type="number" asp-for="StressLevel" />
        <br /><br />

        <label>Sleep Hours</label><br />
        <input type="number" step="0.1" asp-for="SleepHours" />
        <br /><br />

        <label>Anxiety Level (1-10)</label><br />
        <input type="number" asp-for="AnxietyLevel" />
        <br /><br />

        <label>Mood Swings (0-7)</label><br />
        <input type="number" asp-for="MoodSwings" />
        <br /><br />

        <label>Concentration Problem</label><br />
        <select asp-for="ConcentrationProblem">
            <option value="0">No</option>
