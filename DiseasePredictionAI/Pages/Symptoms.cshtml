@page
@model DiseasePredictionAI.Pages.SymptomsModel

<h1>@Model.Department Prediction</h1>

<form method="post">

    <input type="hidden" asp-for="Department" />

    @if (Model.Department == "Cardiology")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Gender</label><br />
        <select asp-for="Gender">
            <option value="1">Male</option>
            <option value="0">Female</option>
        </select>
        <br /><br />

        <label>Blood Pressure</label><br />
        <input type="number" asp-for="BloodPressure" />
        <br /><br />

        <label>Cholesterol</label><br />
        <input type="number" asp-for="Cholesterol" />
        <br /><br />

        <label>Heart Rate</label><br />
        <input type="number" asp-for="HeartRate" />
        <br /><br />
    }

    @if (Model.Department == "Orthopedic")
    {
        <label>Pelvic Incidence</label><br />
        <input type="number" step="0.01" asp-for="PelvicIncidence" />
        <br /><br />

        <label>Pelvic Tilt</label><br />
        <input type="number" step="0.01" asp-for="PelvicTilt" />
        <br /><br />

        <label>Sacral Slope</label><br />
        <input type="number" step="0.01" asp-for="SacralSlope" />
        <br /><br />
    }

    @if (Model.Department == "Psychology")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Sleep Hours</label><br />
        <input type="number" step="0.1" asp-for="SleepHours" />
        <br /><br />

        <label>Stress Level (1-10)</label><br />
        <input type="number" asp-for="StressLevel" />
        <br /><br />
    }

    @if (Model.Department == "Medicine")
    {
        <label>Age</label><br />
        <input type="number" asp-for="Age" />
        <br /><br />

        <label>Glucose</label><br />
        <input type="number" asp-for="Glucose" />
        <br /><br />

        <label>BMI</label><br />
        <input type="number" step="0.1" asp-for="BMI" />
        <br /><br />
    }

    <button type="submit" class="btn btn-primary">
        Predict Disease
    </button>

</form>

@if (!string.IsNullOrEmpty(Model.Result))
{
    <div style="
        margin-top:30px;
        padding:25px;
        border-radius:15px;
        border:2px solid #ddd;
        background:#f8f9fa;">

        <h2>Prediction Result</h2>

        @if (Model.Result.Contains("Risk"))
        {
            <h3 style="color:red;">
                @Model.Result
            </h3>
        }
        else
        {
            <h3 style="color:green;">
                @Model.Result
            </h3>
        }

        <hr />

        <a href="/Symptoms?department=@Model.Department"
           class="btn btn-success">
            Predict Again
        </a>

    </div>
}